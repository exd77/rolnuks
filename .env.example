# ORBLOX - Local development environment
# Copy this file to .env (it's gitignored) and fill in real values

# Application
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Auth (NextAuth v5 / Auth.js)
AUTH_SECRET=development-secret-please-change-in-production-min-32-chars
AUTH_TRUST_HOST=true
NEXTAUTH_URL=http://localhost:3000

# Database (PostgreSQL via Docker Compose)
DATABASE_URL="postgresql://orblox:orblox_dev@localhost:5433/orblox?schema=public"

# Redis (BullMQ + rate limit)
REDIS_URL="redis://localhost:6379"

# Midtrans Payment Gateway
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=

# S3-compatible storage (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=orblox-minio-admin
S3_SECRET_KEY=orblox-minio-password
S3_BUCKET=orblox
S3_PUBLIC_URL=http://localhost:9000/orblox

# Telegram bot for admin order notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
