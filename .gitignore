# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
/coverage

# Next.js
/.next/
/out/

# Production build
/build

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env files (DO NOT commit secrets)
.env
.env.local
.env.*.local
.env.production
!.env.example

# Vercel
.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Misc
*.pem
.cache/
.turbo/

# Docker volumes (in case they're created at workspace root by accident)
/postgres-data/
/redis-data/
/minio-data/

# Prisma
/prisma/migrations.lock

# Devin
/.devin/
